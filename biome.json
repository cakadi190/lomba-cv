{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!public",
      "!utils/colors.js",
      "!prisma/generated",
      "!prisma/seeders/**/*.js",
      "!.nuxt",
      "!.output",
      "!dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.vue"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          },
          "style": {
            "useVueMultiWordComponentNames": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    },
    {
      "includes": ["lib/mailer/template/bases/**/*.html"],
      "linter": {
        "rules": {
          "a11y": {
            "useHtmlLang": "off",
            "useValidAnchor": "off"
          },
          "correctness": {
            "noUnknownProperty": "off"
          },
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    }
  ],
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  }
}
